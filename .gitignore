# Night-shift ENGINE repo (rooted at ~/work). Tracks the orchestrator and its
# contracts/docs; the sibling app projects are their own repos and are
# excluded here.

# Run state (per-project, regenerated each run).
.night-shift/

# Feature specs stay LOCAL ONLY — they carry per-project/product detail and must
# not be published with the engine. The generic templates are kept tracked so the
# engine stays self-contained scaffolding.
/specs/*
!/specs/_template.md
!/specs/_template-web.md

# Feature design + implementation-plan docs are the spec's counterparts and carry
# the same per-project/product detail, so they stay LOCAL ONLY too (same rule as
# /specs/*). Other docs/ — durable engine/validation records — remain tracked.
/docs/superpowers/specs/
/docs/superpowers/plans/

# Independent project repos that live alongside the engine (each has its own git).
/rn-sandbox/
/web-app/
/night-shift-viewer/
/nightshift-demo/
/slack-status/

# Local tooling / machine config — never publish.
.claude/
.DS_Store
*.log

# Node (in case any helper ever adds deps at the root).
node_modules/
agui-jsonrender-rn/
